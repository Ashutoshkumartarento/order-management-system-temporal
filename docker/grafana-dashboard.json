      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"inventory-service\", uri=\"/reserve\", status=\"500\"}[2m])) / sum(rate(http_server_requests_seconds_count{job=\"inventory-service\", uri=\"/reserve\"}[2m]))",
          "legendFormat": "Inventory failure %",
          "refId": "A"
        }
