        <mxCell id="browser" value="🌐 Web Browser&#xa;/ Mobile App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=10;" vertex="1" parent="1">
