        <!-- ══════════════════════════════════════════════════════ -->
        <!-- KONG API GATEWAY -->
        <!-- ══════════════════════════════════════════════════════ -->

        <!-- Kong main box -->
        <mxCell id="kong-main" value="🦍 Kong Gateway&#xa;:8000 (proxy)&#xa;:8001 (admin API)&#xa;:8002 (Konga UI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#003d5b;strokeColor=#003d5b;fontStyle=1;fontSize=11;fontColor=#ffffff;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="200" y="140" width="210" height="90" as="geometry" />
        </mxCell>

        <!-- Kong Routes -->
        <mxCell id="kong-routes" value="📌 Routes&#xa;&#xa;POST /orders/*    → order-svc:8080&#xa;GET  /orders/*    → order-svc:8080&#xa;GET  /workflows/* → order-svc:8080&#xa;*    /inventory/*  → inv-svc:8081&#xa;*    /payments/*   → pay-svc:8082&#xa;*    /shipping/*   → ship-svc:8083" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#003d5b;fontSize=8;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="255" width="210" height="145" as="geometry" />
        </mxCell>

        <!-- Kong Plugins -->
        <mxCell id="kong-plugins" value="🔌 Active Plugins&#xa;&#xa;✓ correlation-id&#xa;✓ rate-limiting (100 req/min)&#xa;✓ proxy-cache (GET 60s)&#xa;✓ prometheus (/metrics)&#xa;✓ request-transformer&#xa;✓ http-log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=8;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="420" width="210" height="145" as="geometry" />
        </mxCell>

        <!-- Konga UI -->
        <mxCell id="konga" value="🖥 Konga Admin UI&#xa;:1337&#xa;&#xa;Visual route manager&#xa;Plugin config UI&#xa;Consumer management&#xa;Traffic analytics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#003d5b;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="200" y="590" width="210" height="110" as="geometry" />
        </mxCell>

        <!-- Kong DB -->
        <mxCell id="kong-db" value="🗄 Kong PostgreSQL&#xa;:5440&#xa;(routes, plugins,&#xa;consumers config)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#003d5b;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="200" y="730" width="210" height="90" as="geometry" />
        </mxCell>


        <!-- ══════════════════════════════════════════════════════ -->
        <!-- MICROSERVICES -->
        <!-- ══════════════════════════════════════════════════════ -->

        <!-- Order Service — the biggest, most complex -->
        <mxCell id="order-svc" value="📦 order-service  :8080&#xa;&#xa;REST API + Temporal Worker&#xa;Event Sourcing + CQRS&#xa;Hexagonal Architecture (inbound ports)&#xa;Saga Orchestrator&#xa;Kafka Producer → order.events&#xa;Swagger UI at /swagger-ui&#xa;&#xa;Write: event_store (append-only JSONB)&#xa;Read:  order_summary projection (CQRS)&#xa;GET /orders — status/customerId filter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontStyle=1;fontSize=9;arcSize=5;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="465" y="120" width="195" height="165" as="geometry" />
        </mxCell>

        <!-- Inventory Service -->
        <mxCell id="inv-svc" value="🏭 inventory-service  :8081&#xa;&#xa;REST: POST /reserve&#xa;REST: DELETE /reserve/{id}&#xa;Own PostgreSQL (inventorydb)&#xa;Kafka Producer → inventory.events&#xa;Configurable failure rate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontStyle=1;fontSize=9;arcSize=5;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="680" y="120" width="195" height="155" as="geometry" />
        </mxCell>

        <!-- Payment Service -->
        <mxCell id="pay-svc" value="💳 payment-service  :8082&#xa;&#xa;REST: POST /charge&#xa;REST: POST /refund&#xa;Own PostgreSQL (paymentdb)&#xa;Kafka Producer → payment.events&#xa;InsufficientFunds (non-retryable)&#xa;CardDeclined (non-retryable)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontStyle=1;fontSize=9;arcSize=5;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="680" y="310" width="195" height="175" as="geometry" />
        </mxCell>

        <!-- Shipping Service -->
        <mxCell id="ship-svc" value="🚚 shipping-service  :8083&#xa;&#xa;REST: POST /shipments&#xa;REST: GET /shipments/{id}&#xa;REST: POST /deliveries&#xa;Own PostgreSQL (shippingdb)&#xa;Kafka Producer → shipping.events&#xa;Carrier simulation (UPS/FedEx)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontStyle=1;fontSize=9;arcSize=5;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="680" y="525" width="195" height="175" as="geometry" />
        </mxCell>

        <!-- Notification Service -->
        <mxCell id="notif-svc" value="🔔 notification-service  :8084&#xa;&#xa;No REST API exposed&#xa;Pure Kafka consumer&#xa;Consumes: order.events&#xa;Consumes: payment.events&#xa;Consumes: shipping.events&#xa;Email / SMS (simulated logs)&#xa;Idempotent — dedup by eventId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontStyle=1;fontSize=9;arcSize=5;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="680" y="740" width="195" height="185" as="geometry" />
        </mxCell>

        <!-- Shared Contracts -->
        <mxCell id="shared-contracts" value="📐 shared-contracts&#xa;(Maven module)&#xa;&#xa;• Kafka event DTOs&#xa;• Common exceptions&#xa;• API contracts (OpenAPI)" style="shape=component;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="900" y="430" width="165" height="120" as="geometry" />
        </mxCell>

        <!-- Activity Notes -->
        <mxCell id="activity-note" value="⚡ Temporal Activities&#xa;(inside order-service worker)&#xa;&#xa;InventoryActivity → HTTP → inv-svc&#xa;PaymentActivity   → HTTP → pay-svc&#xa;ShippingActivity  → HTTP → ship-svc&#xa;NotificationActivity → Kafka pub" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="465" y="340" width="195" height="135" as="geometry" />
        </mxCell>

        <!-- Outbox Pattern Note -->
        <mxCell id="outbox-note" value="📬 Outbox Pattern&#xa;&#xa;Events written to DB first&#xa;then published to Kafka.&#xa;Prevents dual-write problem.&#xa;Guarantees at-least-once." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="465" y="510" width="195" height="115" as="geometry" />
        </mxCell>


        <!-- ══════════════════════════════════════════════════════ -->
        <!-- TEMPORAL ZONE -->
        <!-- ══════════════════════════════════════════════════════ -->

        <mxCell id="temporal-server" value="⏱ Temporal Server&#xa;:7233 (gRPC)&#xa;:7234 (metrics)&#xa;&#xa;Workflow history store&#xa;Task queue routing&#xa;Retry / timeout manager&#xa;At-least-once guarantee" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontStyle=1;fontSize=9;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="1185" y="120" width="230" height="145" as="geometry" />
        </mxCell>

        <mxCell id="workflow-box" value="🔄 OrderFulfillmentWorkflow&#xa;(hosted in order-service worker)&#xa;&#xa;Steps:&#xa;1. Reserve Inventory (HTTP)&#xa;2. Process Payment (HTTP)&#xa;3. Create Shipment (HTTP)&#xa;4. Await Delivery&#xa;&#xa;Signals: cancelOrder, retryPayment&#xa;Queries: status, progress&#xa;&#xa;Saga: compensates on failure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=9;arcSize=5;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1185" y="295" width="230" height="220" as="geometry" />
        </mxCell>

        <mxCell id="temporal-ui" value="🖥 Temporal Web UI&#xa;:8088&#xa;&#xa;Workflow visualizer&#xa;Activity history&#xa;Signal/Query UI&#xa;Replay debugger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1185" y="550" width="230" height="120" as="geometry" />
        </mxCell>

        <mxCell id="temporal-pg" value="🗄 Temporal PostgreSQL&#xa;:5433&#xa;(Temporal's own DB —&#xa;workflow execution history,&#xa;task queues, timers, signals)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1185" y="710" width="230" height="100" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- KAFKA ZONE -->
        <!-- ══════════════════════════════════════════════════════ -->

        <mxCell id="zookeeper" value="🦒 Zookeeper :2181&#xa;(Kafka coordination)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#6a1b9a;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1490" y="120" width="230" height="60" as="geometry" />
        </mxCell>

        <mxCell id="kafka-broker" value="📨 Apache Kafka :9092&#xa;&#xa;Topics:&#xa;  order.events&#xa;  inventory.events&#xa;  payment.events&#xa;  shipping.events&#xa;  notification.requests&#xa;&#xa;Partitioned by orderId&#xa;3 partitions, RF=1 (dev)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#6a1b9a;fontStyle=1;fontSize=9;arcSize=5;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1490" y="205" width="230" height="210" as="geometry" />
        </mxCell>

        <mxCell id="kafka-ui" value="🖥 Kafka UI :9000&#xa;&#xa;Topic browser&#xa;Consumer group lag&#xa;Message inspector&#xa;Produce test messages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#6a1b9a;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1490" y="450" width="230" height="115" as="geometry" />
        </mxCell>

        <mxCell id="consumer-groups" value="👥 Consumer Groups&#xa;&#xa;notification-service-group&#xa;  ← order.events&#xa;  ← payment.events&#xa;  ← shipping.events&#xa;&#xa;order-service-group&#xa;  ← shipping.events (delivery)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#6a1b9a;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1490" y="600" width="230" height="165" as="geometry" />
        </mxCell>


        <!-- ══════════════════════════════════════════════════════ -->
        <!-- DATA STORES ZONE -->
        <!-- ══════════════════════════════════════════════════════ -->

        <mxCell id="db-order" value="🗄 orderdb :5432&#xa;&#xa;event_store (append-only)&#xa;order_snapshots&#xa;&#xa;JSONB events, optimistic lock&#xa;snapshot every 50 events" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#b3e5fc;strokeColor=#0277bd;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1795" y="120" width="185" height="120" as="geometry" />
        </mxCell>

        <mxCell id="db-inventory" value="🗄 inventorydb :5434&#xa;&#xa;inventory_items&#xa;reservations&#xa;outbox_events" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#b3e5fc;strokeColor=#0277bd;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1795" y="275" width="185" height="100" as="geometry" />
        </mxCell>

        <mxCell id="db-payment" value="🗄 paymentdb :5435&#xa;&#xa;transactions&#xa;refunds&#xa;outbox_events" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#b3e5fc;strokeColor=#0277bd;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1795" y="410" width="185" height="100" as="geometry" />
        </mxCell>

        <mxCell id="db-shipping" value="🗄 shippingdb :5436&#xa;&#xa;shipments&#xa;deliveries&#xa;outbox_events" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#b3e5fc;strokeColor=#0277bd;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1795" y="545" width="185" height="100" as="geometry" />
        </mxCell>

        <mxCell id="db-temporal" value="🗄 temporal-pg :5433&#xa;&#xa;Temporal's internal DB&#xa;Workflow exec history&#xa;Task queues, timers" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1795" y="680" width="185" height="100" as="geometry" />
        </mxCell>

        <mxCell id="db-kong" value="🗄 kong-pg :5440&#xa;&#xa;Routes, services&#xa;Plugins config&#xa;Consumers, keys" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#003d5b;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1795" y="815" width="185" height="100" as="geometry" />
        </mxCell>

        <!-- Prometheus + Grafana -->
        <mxCell id="prometheus" value="📊 Prometheus :9090&#xa;Scrapes: Kong /metrics&#xa;All services /actuator/prometheus&#xa;Temporal :7234" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1795" y="950" width="185" height="90" as="geometry" />
        </mxCell>


        <!-- ══════════════════════════════════════════════════════ -->
        <!-- CONNECTIONS -->
        <!-- ══════════════════════════════════════════════════════ -->

        <!-- Client → Kong -->
        <mxCell id="e-browser-kong" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1565c0;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" source="browser" target="kong-main" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-browser-kong-lbl" value="HTTPS :8000" style="edgeLabel;html=1;fontSize=8;fontStyle=1;" vertex="1" connectable="0" parent="e-browser-kong">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <mxCell id="e-curl-kong" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1565c0;strokeWidth=2;" edge="1" source="curl-client" target="kong-main" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Kong → Order Service -->
        <mxCell id="e-kong-order" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#003d5b;strokeWidth=2.5;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" source="kong-main" target="order-svc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-kong-order-lbl" value="/orders/* /workflows/*" style="edgeLabel;html=1;fontSize=8;fontStyle=1;fontColor=#003d5b;" vertex="1" connectable="0" parent="e-kong-order">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- Kong → Inventory Service -->
        <mxCell id="e-kong-inv" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#003d5b;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" source="kong-routes" target="inv-svc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-kong-inv-lbl" value="/inventory/*" style="edgeLabel;html=1;fontSize=8;fontColor=#003d5b;" vertex="1" connectable="0" parent="e-kong-inv">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- Kong → Payment Service -->
        <mxCell id="e-kong-pay" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#003d5b;strokeWidth=2;exitX=1;exitY=0.6;entryX=0;entryY=0.3;" edge="1" source="kong-routes" target="pay-svc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-kong-pay-lbl" value="/payments/*" style="edgeLabel;html=1;fontSize=8;fontColor=#003d5b;" vertex="1" connectable="0" parent="e-kong-pay">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- Kong → Shipping Service -->
        <mxCell id="e-kong-ship" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#003d5b;strokeWidth=2;exitX=1;exitY=0.75;entryX=0;entryY=0.3;" edge="1" source="kong-routes" target="ship-svc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-kong-ship-lbl" value="/shipping/*" style="edgeLabel;html=1;fontSize=8;fontColor=#003d5b;" vertex="1" connectable="0" parent="e-kong-ship">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- Order Service → Temporal (gRPC) -->
        <mxCell id="e-order-temporal" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#e65100;strokeWidth=2.5;dashed=0;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" source="order-svc" target="temporal-server" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-order-temporal-lbl" value="gRPC :7233&#xa;start/signal/query" style="edgeLabel;html=1;fontSize=8;fontStyle=1;fontColor=#e65100;" vertex="1" connectable="0" parent="e-order-temporal">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- Temporal → Activity (order service worker polls) -->
        <mxCell id="e-temporal-workflow" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#e65100;strokeWidth=2;dashed=1;" edge="1" source="temporal-server" target="workflow-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-temporal-workflow-lbl" value="routes tasks&#xa;to worker" style="edgeLabel;html=1;fontSize=8;" vertex="1" connectable="0" parent="e-temporal-workflow">
          <mxGeometry relative="0.5" as="geometry" />
